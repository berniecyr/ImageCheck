# ─────────────────────────────────────────────────────────────────────────────
# SECRETS & CREDENTIALS  (never commit these)
# ─────────────────────────────────────────────────────────────────────────────
login.env
*.env

# ─────────────────────────────────────────────────────────────────────────────
# RUNTIME-GENERATED CONFIG  (auto-created on first run from code templates)
# ─────────────────────────────────────────────────────────────────────────────
config.ini
events.json

# ─────────────────────────────────────────────────────────────────────────────
# DATABASE  (private surveillance data)
# ─────────────────────────────────────────────────────────────────────────────
*.db
*.db-wal
*.db-shm

# ─────────────────────────────────────────────────────────────────────────────
# BIOMETRIC / PRIVATE MEDIA  (training faces, detections, retained footage)
# ─────────────────────────────────────────────────────────────────────────────
Baseline/
Inbox/
Retained_Media/
Output_Faces/
Output_NUDITY/

# ─────────────────────────────────────────────────────────────────────────────
# AI MODEL WEIGHTS  (large binary files — downloaded/cached at runtime)
# ─────────────────────────────────────────────────────────────────────────────
*.pt
*.onnx
*.engine
known_faces.dat

# ─────────────────────────────────────────────────────────────────────────────
# GENERATED AUDIO  (TTS cache, recreated automatically)
# ─────────────────────────────────────────────────────────────────────────────
Recordings/

# ─────────────────────────────────────────────────────────────────────────────
# LOGS
# ─────────────────────────────────────────────────────────────────────────────
logs/

# ─────────────────────────────────────────────────────────────────────────────
# PYTHON
# ─────────────────────────────────────────────────────────────────────────────
venv/
__pycache__/
*.pyc
*.pyo
*.pyd
*.egg-info/
dist/
build/
.Python

# ─────────────────────────────────────────────────────────────────────────────
# PYINSTALLER  (if you ever freeze the app to an .exe)
# ─────────────────────────────────────────────────────────────────────────────
*.spec
dist/
build/

# ─────────────────────────────────────────────────────────────────────────────
# WINDOWS & EDITOR JUNK
# ─────────────────────────────────────────────────────────────────────────────
Thumbs.db
desktop.ini
*.url
.DS_Store
.idea/
.vscode/
